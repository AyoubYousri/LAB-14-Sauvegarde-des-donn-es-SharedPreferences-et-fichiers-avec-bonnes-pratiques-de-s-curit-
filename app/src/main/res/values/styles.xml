<resources>
    <!-- Thème principal de l'application -->
    <style name="Theme.SecureStorageLabJava" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Couleurs primaires et secondaires -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/secondary</item>

        <!-- Personnalisation de l'arrière-plan -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Police par défaut -->
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Style pour les boutons de sauvegarde -->
    <style name="ButtonStyle.Save" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/btn_save</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Style pour les boutons de chargement -->
    <style name="ButtonStyle.Load" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/btn_load</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Style pour le bouton d'exportation -->
    <style name="ButtonStyle.Export" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/btn_export</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Style pour le bouton d'effacement -->
    <style name="ButtonStyle.Clear" parent="Widget.AppCompat.Button">
        <item name="android:backgroundTint">@color/btn_delete</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Style pour les champs de saisie -->
    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@drawable/edit_text_bg</item>
    </style>
</resources>
